# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Public anon key (safe for server auth calls; do not expose in uncontrolled client bundles)
SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional but recommended: service role — ONLY on server. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI providers
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Legacy message cap (still used as safety fallback)
FREE_AI_MESSAGES_PER_MONTH=60
